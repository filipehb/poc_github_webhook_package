PORT=3000
WEBHOOK_SECRET=your-github-webhook-secret

# Optional filters (leave empty to accept any matching container package)
PACKAGE_OWNER=filipehb
PACKAGE_NAME=my-app
IMAGE_TAG=latest

# Redeploy target (set one of these)
COMPOSE_FILE=/opt/my-app/docker-compose.yml
# CONTAINER_NAME=my-app

# GHCR credentials for docker login on the VPS (not used by Node directly)
GHCR_USERNAME=filipehb
GHCR_TOKEN=

# Optional: force pull platform (use linux/amd64 on Apple Silicon Mac until multi-arch image is published)
# DOCKER_PLATFORM=linux/amd64
